{
  "name": "guzek-uk-website",
  "homepage": "https://www.guzek.uk/",
  "version": "5.0.0",
  "type": "module",
  "engines": {
    "node": "^24.14.0"
  },
  "author": "Konrad Guzek",
  "license": "AGPL-3.0-only",
  "description": "The static portfolio website for guzek.uk.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prerender.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "types:check": "tsc --noEmit",
    "ci": "pnpm types:check && pnpm lint && pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "@codaworks/react-glow": "^1.0.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-icons": "^16.23.0",
    "tailwind-merge": "^3.6.0",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "latest",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "knip": "^6.17.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "latest"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown",
    "*.ts?(x)": "eslint"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "@swc/core",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "volta": {
    "node": "24.14.0"
  }
}
